{
  "name": "crmslot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:stop": "bash scripts/dev/stop-dev-servers.sh",
    "dev:fresh": "npm run dev:stop && npm run clean:dev && npm run dev",
    "dev:status": "bash -c 'if pgrep -f \"next dev\" >/dev/null; then echo \"next dev: actif — http://localhost:3000\"; pgrep -fl \"next dev\"; else echo \"next dev: arrêté\"; fi'",
    "ram:agents": "bash scripts/dev/ram-agents.sh",
    "ram:status": "bash scripts/dev/ram-status.sh",
    "dev:mobile": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:pwa": "ENABLE_PWA_IN_DEV=true next dev --turbo",
    "build": "node scripts/dev/sync-mapbox-worker.mjs && node scripts/pwa/sync-manifests.mjs && next build --webpack",
    "sync:pwa-manifests": "node scripts/pwa/sync-manifests.mjs",
    "start": "next start",
    "prod": "npm run build && npm run start",
    "lint": "eslint",
    "lint:ci": "eslint src tests jest.setup.ts scripts --quiet",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:chatbot": "jest src/features/chatbot --no-coverage",
    "test:chatbot:coverage": "jest src/features/chatbot --coverage",
    "test:interventions": "jest src/features/interventions --no-coverage",
    "test:feature-hub": "jest src/features/featureHub src/features/catalog --no-coverage",
    "test:gmail": "jest src/features/gmail --no-coverage",
    "test:crm": "jest src/features/crmHistory --no-coverage",
    "test:billing-hub": "jest src/features/billingHub src/features/billing --no-coverage",
    "test:patron-hubs": "jest src/features/caseHub src/features/teamHub src/features/planningHub src/features/commissionsHub src/core/ui/hub --no-coverage",
    "test:webhooks": "jest src/app/api/webhooks --no-coverage",
    "test:mobile-infra": "jest src/features/mobile src/features/app/__tests__/DesktopOnlyGate.test.tsx src/core/config/__tests__/mobileClientDetection.test.ts src/core/config/__tests__/mobileAccess.test.ts src/core/config/__tests__/mobileDevOrigins.test.ts src/core/ui/__tests__/useIsMobile.test.ts --no-coverage",
    "test:mobile-shell": "jest src/features/dashboard/__tests__/mobileShellContract.test.tsx src/features/dashboard/components/__tests__/MobileShell.test.tsx src/features/dashboard/components/__tests__/MobileScreenHost.test.tsx src/features/dashboard/components/__tests__/DashboardPageSelector.test.tsx src/features/dashboard/components/__tests__/UserProfile.test.tsx src/features/dashboard/components/__tests__/DashboardDesktopShell.test.tsx src/features/dashboard/components/__tests__/MobileHeaderRailLayout.test.tsx src/features/dashboard/components/__tests__/MobileTopBar.test.tsx --no-coverage",
    "test:mobile-admin": "jest src/features/dashboard/__tests__/adminMobileShellContract.test.tsx src/core/pwa/__tests__/PwaUpdateBanner.test.tsx src/core/pwa/__tests__/pwaBundleUpdate.test.ts src/features/offline/__tests__/adminInboxInterventionsCache.test.ts src/features/offline/__tests__/adminInterventionDetailCache.test.ts src/features/backoffice/__tests__/useBackOfficeInterventions.offline.test.ts --no-coverage",
    "test:e2e:mobile": "playwright test tests/e2e/mobile-shell.spec.ts tests/e2e/api-mobile-config.spec.ts tests/e2e/api-pwa-registry.spec.ts --project=mobile-shell --project=chromium",
    "test:e2e:desktop-gate": "PLAYWRIGHT_GATE_E2E=1 playwright test tests/e2e/desktop-only-gate-prod.spec.ts --project=desktop-gate-prod --project=desktop-gate-prod-chrome",
    "test:ci": "npm run typecheck && npm run test:coverage",
    "test:agent-check": "node scripts/ci/agent-test-check.mjs",
    "test:agent-check:main": "node scripts/ci/agent-test-check.mjs --base=origin/main",
    "agent:score": "node scripts/ci/agent-score.mjs",
    "coverage:ratchet": "node scripts/ci/check-coverage-ratchet.mjs",
    "coverage:ratchet:update": "node scripts/ci/check-coverage-ratchet.mjs --update",
    "coverage:uncovered": "node scripts/ci/check-coverage-ratchet.mjs --list-uncovered",
    "test:contract": "jest tests/contract --no-coverage",
    "test:untested": "node scripts/ci/list-untested-modules.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ci": "CI=true playwright test",
    "test:e2e:chatbot": "playwright test tests/e2e/chatbot-local-intent.spec.ts",
    "test:e2e:invoice": "playwright test tests/e2e/invoice-validation.spec.ts",
    "test:e2e:company": "playwright test tests/e2e/company-hub-request.spec.ts",
    "test:e2e:portal-chat": "playwright test tests/e2e/portal-chat-smoke.spec.ts tests/e2e/portal-chat-client-ui.spec.ts --project=chromium --project=portal-chat-client",
    "test:e2e:technician": "playwright test tests/e2e/technician-finish-job.spec.ts",
    "test:e2e:offline": "playwright test tests/e2e/offline-sync.spec.ts",
    "test:e2e:api-matrix": "playwright test tests/e2e/api-routes-auth-matrix.spec.ts",
    "generate:api-routes": "node scripts/ci/generate-protected-api-routes.mjs",
    "map": "node scripts/ci/generate-codemap.mjs",
    "audit:barrels": "node scripts/ci/audit-barrels.mjs",
    "audit:barrels:public": "node scripts/ci/detect-cross-feature-imports.mjs",
    "audit:barrels:suggest": "node scripts/ci/detect-cross-feature-imports.mjs --suggest",
    "ci": "npm run lint:ci && npm run audit:barrels:client-safe && npm run test:ci && npm run build",
    "clean:dev": "bash scripts/dev/clean-dev-artifacts.sh",
    "ci:all": "npm run ci && npm run test:e2e",
    "verify:env": "node scripts/ops/verify-env.mjs --tier=staging",
    "verify:env:prod": "node scripts/ops/verify-env.mjs --tier=production",
    "smoke:url": "node scripts/ops/smoke-url.mjs",
    "sync:vercel-env": "node scripts/ops/sync-vercel-env.mjs",
    "vercel:ids": "node scripts/ops/print-vercel-ids.mjs",
    "release:check": "npm run verify:env && npm run ci:all",
    "release:check:prod": "npm run verify:env:prod && npm run ci:all",
    "pretypecheck": "node scripts/dev/prune-next-type-duplicates.mjs",
    "typecheck": "tsc --noEmit",
    "fetch:lecot-images": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/lecot/fetch-lecot-product-images.ts",
    "fetch:lecot-images:full": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/lecot/fetch-lecot-product-images-full.ts",
    "fetch:lecot-images:report": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/lecot/lecot-image-report.ts",
    "fetch:lecot-images:verify": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/lecot/lecot-image-verify.ts",
    "probe:lecot-images": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/lecot/probe-lecot-image-access.ts",
    "seed:lecot-image-index": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/lecot/seed-lecot-image-index-from-legacy.ts",
    "export:chatbot-training": "ts-node scripts/chatbot/export-chatbot-training-jsonl.ts",
    "sync:technician-uids": "node scripts/ops/sync-technician-auth-uids.mjs",
    "check:technician-uids": "node scripts/ops/sync-technician-auth-uids.mjs --check",
    "list:technician-uids": "node scripts/ops/sync-technician-auth-uids.mjs --list",
    "deploy:firestore-rules": "firebase deploy --only firestore:rules",
    "cap:sync": "cap sync",
    "cap:sync:ios": "cap sync ios",
    "cap:sync:android": "cap sync android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:icons": "npx @capacitor/assets generate --iconBackgroundColor '#09090B' --splashBackgroundColor '#09090B' --android --ios",
    "cap:sync:terrain": "CAPACITOR_SERVER_URL=https://crmslot.vercel.app/m/technician cap sync",
    "cap:sync:terrain:ios": "CAPACITOR_SERVER_URL=https://crmslot.vercel.app/m/technician cap sync ios",
    "cap:sync:terrain:android": "CAPACITOR_SERVER_URL=https://crmslot.vercel.app/m/technician cap sync android",
    "cap:sync:client": "CAPACITOR_SERVER_URL=https://crmslot.vercel.app/m/demande cap sync",
    "cap:sync:client:android": "CAPACITOR_SERVER_URL=https://crmslot.vercel.app/m/demande cap sync android",
    "cap:sync:admin": "CAPACITOR_SERVER_URL=https://crmslot.vercel.app cap sync",
    "cap:sync:admin:android": "CAPACITOR_SERVER_URL=https://crmslot.vercel.app cap sync android",
    "cap:sync:admin:ios": "CAPACITOR_SERVER_URL=https://crmslot.vercel.app cap sync ios",
    "test:e2e:technician-app": "playwright test tests/e2e/technician-mobile-app.spec.ts --project=technician-app",
    "test:e2e:client-app": "playwright test tests/e2e/client-mobile-app.spec.ts --project=client-app",
    "test:e2e:satellite-apps": "playwright test tests/e2e/technician-mobile-app.spec.ts tests/e2e/client-mobile-app.spec.ts --project=technician-app --project=client-app",
    "test:native-infra": "jest src/core/native src/features/interventions/__tests__/technicianHubNavigation.test.ts src/features/company/__tests__/companyHubNavigation.test.ts src/features/company/components/__tests__/ClientMobileApp.test.tsx src/features/notifications/__tests__/technicianNotificationIntent.test.ts --no-coverage",
    "cap:install:android:debug": "cd android && ../scripts/mobile/gradlew-with-jbr.sh installDebug",
    "prepare": "husky",
    "i18n:parity": "node scripts/i18n/parity-check.mjs --require ru",
    "test:i18n": "jest src/core/i18n --no-coverage",
    "audit:barrels:client-safe": "node scripts/ci/detect-cross-feature-imports.mjs --verify-client-safe"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor-firebase/messaging": "^8.3.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^7.6.6",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@googleapis/gmail": "^10.0.0",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@sentry/nextjs": "^10.57.0",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "@tanstack/query-sync-storage-persister": "^5.100.9",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-persist-client": "^5.100.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.38.0",
    "google-auth-library": "^9.0.0",
    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.14.0",
    "mapbox-gl": "^3.22.0",
    "next": "16.2.4",
    "nodemailer": "^8.0.7",
    "openai": "^6.35.0",
    "pdfjs-dist": "^4.10.38",
    "posthog-js": "^1.386.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "twilio": "^6.0.0",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --quiet",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "^16.2.6",
    "@next/swc-linux-x64-gnu": "^16.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
