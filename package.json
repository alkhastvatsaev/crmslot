{
  "name": "belgmap",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:mobile": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:pwa": "ENABLE_PWA_IN_DEV=true next dev --turbo",
    "build": "next build --webpack",
    "start": "next start",
    "prod": "npm run build && npm run start",
    "lint": "eslint",
    "lint:ci": "eslint src tests jest.setup.ts scripts --quiet",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:chatbot": "jest src/features/chatbot --no-coverage",
    "test:chatbot:coverage": "jest src/features/chatbot --coverage",
    "test:interventions": "jest src/features/interventions --no-coverage",
    "test:feature-hub": "jest src/features/featureHub src/features/catalog --no-coverage",
    "test:gmail": "jest src/features/gmail --no-coverage",
    "test:crm": "jest src/features/crmHistory --no-coverage",
    "test:billing-hub": "jest src/features/billingHub src/features/billing --no-coverage",
    "test:webhooks": "jest src/app/api/webhooks --no-coverage",
    "test:mobile-infra": "jest src/features/mobile src/features/app/__tests__/DesktopOnlyGate.test.tsx src/core/config/__tests__/mobileClientDetection.test.ts src/core/config/__tests__/mobileAccess.test.ts src/core/config/__tests__/mobileDevOrigins.test.ts src/core/ui/__tests__/useIsMobile.test.ts --no-coverage",
    "test:mobile-shell": "jest src/features/dashboard/__tests__/mobileShellContract.test.tsx src/features/dashboard/components/__tests__/MobileShell.test.tsx src/features/dashboard/components/__tests__/MobileScreenHost.test.tsx src/features/dashboard/components/__tests__/DashboardPageSelector.test.tsx src/features/dashboard/components/__tests__/UserProfile.test.tsx src/features/dashboard/components/__tests__/DashboardDesktopShell.test.tsx src/features/dashboard/components/__tests__/MobileHeaderRailLayout.test.tsx src/features/dashboard/components/__tests__/MobileTopBar.test.tsx --no-coverage",
    "test:e2e:mobile": "playwright test tests/e2e/mobile-shell.spec.ts tests/e2e/api-mobile-config.spec.ts tests/e2e/api-pwa-registry.spec.ts --project=mobile-shell --project=chromium",
    "test:e2e:desktop-gate": "PLAYWRIGHT_GATE_E2E=1 playwright test tests/e2e/desktop-only-gate-prod.spec.ts --project=desktop-gate-prod --project=desktop-gate-prod-chrome",
    "test:ci": "npm run typecheck && npm run test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:ci": "CI=true playwright test",
    "test:e2e:chatbot": "playwright test tests/e2e/chatbot-local-intent.spec.ts",
    "test:e2e:invoice": "playwright test tests/e2e/invoice-validation.spec.ts",
    "test:e2e:company": "playwright test tests/e2e/company-hub-request.spec.ts",
    "test:e2e:technician": "playwright test tests/e2e/technician-finish-job.spec.ts",
    "test:e2e:offline": "playwright test tests/e2e/offline-sync.spec.ts",
    "test:e2e:api-matrix": "playwright test tests/e2e/api-routes-auth-matrix.spec.ts",
    "generate:api-routes": "node scripts/generate-protected-api-routes.mjs",
    "ci": "npm run lint:ci && npm run test:ci && npm run build",
    "ci:all": "npm run ci && npm run test:e2e",
    "verify:env": "node scripts/verify-env.mjs --tier=staging",
    "verify:env:prod": "node scripts/verify-env.mjs --tier=production",
    "smoke:url": "node scripts/smoke-url.mjs",
    "vercel:ids": "node scripts/print-vercel-ids.mjs",
    "release:check": "npm run verify:env && npm run ci:all",
    "release:check:prod": "npm run verify:env:prod && npm run ci:all",
    "pretypecheck": "node scripts/prune-next-type-duplicates.mjs",
    "typecheck": "tsc --noEmit",
    "fetch:lecot-images": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/fetch-lecot-product-images.ts",
    "fetch:lecot-images:full": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/fetch-lecot-product-images-full.ts",
    "fetch:lecot-images:report": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/lecot-image-report.ts",
    "fetch:lecot-images:verify": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/lecot-image-verify.ts",
    "probe:lecot-images": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/probe-lecot-image-access.ts",
    "seed:lecot-image-index": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/seed-lecot-image-index-from-legacy.ts",
    "export:chatbot-training": "ts-node scripts/export-chatbot-training-jsonl.ts",
    "sync:technician-uids": "node scripts/sync-technician-auth-uids.mjs",
    "check:technician-uids": "node scripts/sync-technician-auth-uids.mjs --check",
    "list:technician-uids": "node scripts/sync-technician-auth-uids.mjs --list",
    "deploy:firestore-rules": "firebase deploy --only firestore:rules",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@google/genai": "^2.6.0",
    "@google/generative-ai": "^0.24.1",
    "@googleapis/gmail": "^10.0.0",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@sentry/nextjs": "^10.57.0",
    "@tanstack/query-sync-storage-persister": "^5.100.9",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-persist-client": "^5.100.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.38.0",
    "google-auth-library": "^9.0.0",
    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.14.0",
    "mapbox-gl": "^3.22.0",
    "next": "16.2.4",
    "nodemailer": "^8.0.7",
    "openai": "^6.35.0",
    "pdfjs-dist": "^4.10.38",
    "posthog-js": "^1.386.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "twilio": "^6.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --quiet",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "^16.2.6",
    "@next/swc-linux-x64-gnu": "^16.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
