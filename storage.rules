rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function interventionDoc(interventionId) {
      return firestore.get(/databases/(default)/documents/interventions/$(interventionId));
    }

    function canAccessInterventionStorage(interventionId) {
      let iv = interventionDoc(interventionId);
      return request.auth != null
        && iv != null
        && iv.data != null
        && (
          (
            iv.data.keys().hasAny(['assignedTechnicianUid'])
            && iv.data.assignedTechnicianUid is string
            && iv.data.assignedTechnicianUid.size() > 0
            && iv.data.assignedTechnicianUid == request.auth.uid
          )
          || (
            iv.data.keys().hasAny(['createdByUid'])
            && iv.data.createdByUid == request.auth.uid
          )
          || (
            iv.data.keys().hasAny(['companyId'])
            && iv.data.companyId is string
            && iv.data.companyId.size() > 0
            && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)/company_memberships/$(iv.data.companyId))
          )
        );
    }

    /** Photos + signature de fin d’intervention — utilisateurs authentifiés uniquement. */
    match /interventions/{interventionId}/completion/{fileName} {
      allow read: if canAccessInterventionStorage(interventionId);
      allow write: if canAccessInterventionStorage(interventionId)
        && request.resource.size < 15 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/jpeg')
          || request.resource.contentType.matches('image/png')
        );
    }

    /** Audio (message vocal du client) - utilisateurs authentifiés uniquement. */
    match /interventions/{interventionId}/{audioFile} {
      allow read: if canAccessInterventionStorage(interventionId);
      allow write: if canAccessInterventionStorage(interventionId)
        && request.resource.size < 15 * 1024 * 1024
        && audioFile.matches('audio\\.(webm|mp4)');
    }

    // Extensions : WebM, MP4/M4A (Safari), OGG, WAV — cf. extFromBlob dans clientAudioUpload.ts
    // Lecture : propriétaire du clip uniquement. Le pipeline serveur passe par Admin SDK
    // (transcription, dispatch) qui contourne les rules. Évite la fuite cross-tenant des audio.
    match /interventions_audio/{uid}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 15 * 1024 * 1024
        && fileName.matches('.*\\.(webm|mp4|m4a|ogg|wav)');
    }

    /** Factures PDF (écriture Admin SDK / Functions uniquement). */
    match /invoices/{fileName} {
      allow read: if false;
      allow write: if false;
    }

    /**
     * Chat IVANA (portail / inbox) — images liées à `portal_ivana_chat_messages.imageUrls`.
     * Chemin : companyId / uid auteur / fichier.
     * Lecture : staff de la société OU client lié à la société (même check que pour write).
     * Avant : `request.auth != null` exposait les images du chat à toutes les sociétés.
     */
    match /portal_ivana_chat/{companyId}/{userId}/{fileName} {
      allow read: if request.auth != null
        && (
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)/company_memberships/$(companyId))
          || (
            firestore.exists(/databases/(default)/documents/client_portal_profiles/$(request.auth.uid))
            && firestore.get(/databases/(default)/documents/client_portal_profiles/$(request.auth.uid)).data.companyId == companyId
          )
        );
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && (
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)/company_memberships/$(companyId))
          || (
            firestore.exists(/databases/(default)/documents/client_portal_profiles/$(request.auth.uid))
            && firestore.get(/databases/(default)/documents/client_portal_profiles/$(request.auth.uid)).data.companyId == companyId
          )
        );
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
