# ── Firebase (obligatoire sur Vercel pour auth + Firestore réels) ──
# Admin (serveur) — Firebase Console → Paramètres projet → Comptes de service → Générer une clé JSON
# Copier project_id, client_email, private_key dans .env.local (ou tout le JSON dans FIREBASE_SERVICE_ACCOUNT_JSON)
# FIREBASE_PROJECT_ID=mon-projet
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@mon-projet.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optionnel — laisser vide si vous n’utilisez pas Realtime Database
# NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# ── Carte ──
NEXT_PUBLIC_MAPBOX_TOKEN=
# Optionnel — géocodage serveur (sinon repli sur NEXT_PUBLIC_MAPBOX_TOKEN)
# MAPBOX_ACCESS_TOKEN=

# ── Staging preview (tenant démo si pas de Firebase / pas de membership) ──
# Local : activé automatiquement (NODE_ENV=development).
# Vercel : NEXT_PUBLIC_STAGING_PREVIEW=true (Production + Preview) + auth anonyme Firebase.
# Couper : NEXT_PUBLIC_DISABLE_DEV_UI_PREVIEW=true
# Les missions / clients fictifs (mock-day-*, generateDailyMissions) ne sont plus injectés dans l’UI.

# Démo commerciale : floute noms, photos et audio (désactivé par défaut en prod)
# NEXT_PUBLIC_PRESENTATION_PRIVACY_MODE=true

# ── Mobile PWA (staging / iPhone) ──
# Autoriser l'app sur téléphone (bypass DesktopOnlyGate en prod/staging)
# NEXT_PUBLIC_ALLOW_MOBILE=true
#
# Simuler mobile sur desktop : http://localhost:3000/?forceMobile=1
#
# Tunnel ngrok / iPhone en dev — domaine sans https:// (relancer npm run dev après changement)
# NGROK_DEV_ORIGIN=gains-buckle-violation.ngrok-free.dev
#
# Tests E2E shell mobile : npx playwright test tests/e2e/mobile-shell.spec.ts
# Config mobile API : GET /api/mobile/config (public)

# Feature flags (true / false) — overrides possibles dans Firestore companies/{id}.featureFlags
# NEXT_PUBLIC_FF_UNIFIED_FIELD_COCKPIT=true
# NEXT_PUBLIC_FF_INTERVENTION_COMMAND_PALETTE=true
# NEXT_PUBLIC_FF_COMMISSIONS_V2=true
# NEXT_PUBLIC_FF_CRM_CONTACTS=false
# NEXT_PUBLIC_FF_LECOT_PRODUCT_SEARCH=false
# Lot PWA v2 (CRM→BO, checklist, KPI, relances, devis PDF, export CRM…)
# NEXT_PUBLIC_FF_PWA_V2=true
# Devis avant facturation (QuoteListPanel / QuoteEditorPanel)
# NEXT_PUBLIC_FF_QUOTES=false
# Contrats de maintenance récurrents (panneau CRM client + cron /api/maintenance/generate-due)
# NEXT_PUBLIC_FF_MAINTENANCE=false
# Suivi SLA par priorité (badge back-office)
# NEXT_PUBLIC_FF_SLA=false
# Géofencing auto — toast arrivée + transition statut (hub technicien)
# NEXT_PUBLIC_FF_GEOFENCE=false
# Stock véhicule technicien (hub technicien, rail droit)
# NEXT_PUBLIC_FF_VEHICLE_STOCK=false
# Notifications WhatsApp Twilio (route /api/notifications/whatsapp + statuts en_route/done)
# NEXT_PUBLIC_FF_WHATSAPP=false
# Parc matériel client (panneau CRM client)
# NEXT_PUBLIC_FF_EQUIPMENT_INVENTORY=false
# Portail fournisseur Lecot (SupplierOrderPanel)
# NEXT_PUBLIC_FF_SUPPLIER_PORTAL=false
#
# Secret cron Vercel (génération interventions de maintenance dues)
# CRON_SECRET=
#
# Monitoring Sentry (no-op complet si DSN absent)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# API catalogue Lecot (optionnel — sans URL, catalogue démo local via /api/catalog/lecot-search)
# LECOT_API_URL=https://api.example.com/v1
# LECOT_API_BASE_URL=   # alias de LECOT_API_URL
# LECOT_API_KEY=
# LECOT_API_TOKEN=      # alias de LECOT_API_KEY
# LECOT_API_SEARCH_PATH=/products/search
#
# Site pro Lecot (lecot.be — scraping Playwright + liens Chatbot). Identifiants : .env.local uniquement.
# LECOT_SHOP_URL=https://lecot.be/nl-be
# NEXT_PUBLIC_LECOT_SHOP_URL=https://lecot.be/nl-be
# Variante FR : https://lecot.be/fr-be
# LECOT_SHOP_EMAIL=
# LECOT_SHOP_PASSWORD=
# Playwright : désactivé par défaut (catalogue local data/catalog/lecot/products.json).
# Activer seulement après : npx playwright install  puis LECOT_PLAYWRIGHT_SEARCH=true
# LECOT_PLAYWRIGHT_ORDER=true

# Technicien assigné par défaut depuis le back-office (UID Firebase Auth du compte terrain)
# Console Firebase → Authentication → utilisateur → UID (pas l’id doc Firestore technicians/*)
# NEXT_PUBLIC_DEFAULT_ASSIGNED_TECHNICIAN_UID=
# Après définition + FIREBASE_* Admin : npm run sync:technician-uids  |  npm run check:technician-uids

# ── Sécurité API (production recommandé) ──
# Secret pour traitement auto des uploads bureau / cron
# UPLOAD_AUTO_PROCESS_SECRET=
# Secret MacroDroid → en-tête HTTP x-audio-dispatch-secret sur POST /api/ai/audio-dispatch
# AUDIO_DISPATCH_SECRET=
# IP bureau + autoriser process-uploads sans jeton (optionnel)
# NEXT_PUBLIC_OFFICE_IP=
# OFFICE_ALLOW_UPLOAD_AUTO_PROCESS=true

# ── Intégrations serveur (jamais exposer côté client) ──
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# WhatsApp Business — numéro Twilio WhatsApp sandbox ou approuvé (ex. +14155238886)
# TWILIO_WHATSAPP_FROM=
# URL publique exacte du webhook (ex. https://votre-app.vercel.app) pour valider X-Twilio-Signature
# TWILIO_WEBHOOK_PUBLIC_URL=
# Gmail — envoi emails UI + Chatbot (choisir OAuth **ou** mot de passe d'application)
# Compte Gmail hub page 7 + envoi dossiers (obligatoire pour /api/integrations/gmail/*)
# GMAIL_USER=alkhastvatsaev@gmail.com
# EMAIL_FROM_NAME=MAP BELGIQUE
# REPLY_TO_DOMAIN=mapbelgique.com
#
# Option A — OAuth (recommandé si vous avez un Client ID Google Cloud)
# Console : APIs → Gmail API activée → Identifiants OAuth → URI de redirection :
#   http://localhost:3000/api/integrations/gmail/callback
# Puis connectez : http://localhost:3000/api/integrations/gmail/connect (connecté à l'app)
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxx
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/gmail/callback
# GMAIL_REFRESH_TOKEN=xxxx   # affiché une fois après /api/integrations/gmail/connect (scopes lecture+envoi)
#
# Option B — SMTP (mot de passe d'application Google, sans OAuth)
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=   # Dashboard Stripe → Webhooks → signing secret (/api/webhooks/stripe)
# Paiement simulé sans compte Stripe (auto hors prod si STRIPE_SECRET_KEY absent ; forcer : =1)
# STRIPE_MOCK_MODE=1
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=  # FCM Web Push (Firebase Console → Cloud Messaging)
# PUBLIC_APP_URL=                  # Liens push FCM + retour Stripe (ex. https://votre-app.vercel.app)
# OPENAI_API_KEY=                    # Chatbot (page 5) + transcription — https://platform.openai.com/api-keys
# OPENAI_MODEL=gpt-4o-mini           # (optionnel) modèle Chatbot — défaut gpt-4o-mini
# OPENAI_MODEL=gpt-4o                # ← activer pour vision (analyse photos depuis le Chatbot)
# OPENAI_DISPATCH_MODEL=gpt-4o-mini
#
# ── Collecte données d'entraînement (fine-tuning) ──
# Active le log de chaque tour Chatbot dans companies/{id}/chatbot_training_logs
# Désactivé par défaut (opt-in). Exporter : npm run export:training
# CHATBOT_TRAINING_LOG_ENABLED=true
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Automatisation CI / déploiement (GitHub → Settings → Secrets) ──
# VERCEL_TOKEN=          # https://vercel.com/account/tokens
# VERCEL_ORG_ID=         # vercel project settings
# VERCEL_PROJECT_ID=
# PRODUCTION_URL=        # https://votre-app.vercel.app — smoke hebdo + manuel
