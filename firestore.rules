rules_version = '2';
// Production : voir docs/FIRESTORE_PRODUCTION_MIGRATION.md avant de durcir la lecture globale des interventions.
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function membershipPath(companyId) {
      return /databases/$(database)/documents/users/$(request.auth.uid)/company_memberships/$(companyId);
    }

    function userBelongsToCompany(companyId) {
      return isAuthed()
        && companyId is string
        && companyId.size() > 0
        && exists(membershipPath(companyId));
    }

    function userRoleInCompany(companyId) {
      return get(membershipPath(companyId)).data.role;
    }

    /** Jeton synchronisé via /api/company/sync-claims — obligatoire pour isoler les données tenant. */
    function isCompanyPortalUser() {
      return isAuthed()
        && request.auth.token.keys().hasAll(['bmTenants'])
        && request.auth.token.bmTenants is list
        && request.auth.token.bmTenants.size() > 0;
    }

    function tenantClaimsIncludeCompany(companyId) {
      return isCompanyPortalUser()
        && companyId is string
        && companyId.size() > 0
        && (
          request.auth.token.bmTenants.hasAny([companyId + ':admin'])
          || request.auth.token.bmTenants.hasAny([companyId + ':collaborateur'])
        );
    }

    function clientPortalProfilePath() {
      return /databases/$(database)/documents/client_portal_profiles/$(request.auth.uid);
    }

    /** Demandeur connecté (SSO / magic link) — doc `client_portal_profiles` avec `companyId`. */
    function clientPortalLinkedToCompany(companyId) {
      return isAuthed()
        && companyId is string
        && companyId.size() > 0
        && exists(clientPortalProfilePath())
        && get(clientPortalProfilePath()).data.keys().hasAny(['companyId'])
        && get(clientPortalProfilePath()).data.companyId is string
        && get(clientPortalProfilePath()).data.companyId.size() > 0
        && get(clientPortalProfilePath()).data.companyId == companyId;
    }

    /** Numéro sur liste `allowed_users` avec société explicite (même champs que le client — synchro profil). */
    function allowedUsersPhoneMatchesIvanaCompany(companyId) {
      return isAuthed()
        && companyId is string
        && companyId.size() > 0
        && request.auth.token.phone_number is string
        && exists(/databases/$(database)/documents/allowed_users/$(request.auth.token.phone_number))
        && (
          (
            get(/databases/$(database)/documents/allowed_users/$(request.auth.token.phone_number)).data.keys().hasAny(['portalCompanyId'])
            && get(/databases/$(database)/documents/allowed_users/$(request.auth.token.phone_number)).data.portalCompanyId == companyId
          )
          || (
            get(/databases/$(database)/documents/allowed_users/$(request.auth.token.phone_number)).data.keys().hasAny(['ivanaChatCompanyId'])
            && get(/databases/$(database)/documents/allowed_users/$(request.auth.token.phone_number)).data.ivanaChatCompanyId == companyId
          )
          || (
            get(/databases/$(database)/documents/allowed_users/$(request.auth.token.phone_number)).data.keys().hasAny(['companyId'])
            && get(/databases/$(database)/documents/allowed_users/$(request.auth.token.phone_number)).data.companyId == companyId
          )
        );
    }

    /** Chat IVANA : staff (membership / bmTenants) ou client portail lié à la société. */
    function canAccessIvanaPortalChatCompany(companyId) {
      return companyId is string
        && companyId.size() > 0
        && (
          userBelongsToCompany(companyId)
          || tenantClaimsIncludeCompany(companyId)
          || clientPortalLinkedToCompany(companyId)
          || allowedUsersPhoneMatchesIvanaCompany(companyId)
          || companyId == 'demo-local-company'
        );
    }

    function interventionHasTenantScope(data) {
      return data.keys().hasAny(['companyId'])
        && data.companyId is string
        && data.companyId.size() > 0;
    }

    /** Back-office : un collaborateur peut valider la facturation (done → invoiced) en ne touchant qu’au statut. */
    function tenantCollaborateurCanValidateReport() {
      return request.auth.token.bmTenants.hasAny([resource.data.companyId + ':collaborateur'])
        && resource.data.status == 'done'
        && request.resource.data.status == 'invoiced'
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['status', 'currentOwnerUid', 'currentOwnerRole', 'statusUpdatedAt'])
        && request.resource.data.companyId == resource.data.companyId;
    }

    // --- Prompt 1 : entreprise multi-tenant ---
    match /companies/{companyId} {
      allow read: if userBelongsToCompany(companyId);
      allow create: if isAuthed()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.keys().hasAll(['name', 'createdAt', 'createdByUid']);
      allow update: if isAuthed() && resource.data.createdByUid == request.auth.uid;
      allow delete: if false;

      match /billing/{docId} {
        allow read: if userBelongsToCompany(companyId) && userRoleInCompany(companyId) == 'admin';
        allow write: if false;
      }

      match /products/{productId} {
        allow read: if userBelongsToCompany(companyId);
        allow create, update: if userBelongsToCompany(companyId)
          && userRoleInCompany(companyId) == 'admin'
          && request.resource.data.companyId == companyId
          && request.resource.data.keys().hasAll(['sku', 'label', 'unitPriceCents', 'isActive']);
        allow delete: if false;
      }

      /** Commandes fournisseur (Lecot, etc.) — créées via Admin SDK / Chatbot ; lecture back-office. */
      match /supplierOrders/{orderId} {
        allow read: if userBelongsToCompany(companyId)
          || tenantClaimsIncludeCompany(companyId)
          || companyId == 'demo-local-company';
        allow write: if false;
      }

      /** Logs Q/R chatbot (fine-tuning) — écriture Admin SDK ; lecture admin société uniquement. */
      match /chatbot_training_logs/{logId} {
        allow read: if userBelongsToCompany(companyId) && userRoleInCompany(companyId) == 'admin';
        allow create, update, delete: if false;
      }
    }

    /** Création collaborateur uniquement via Admin SDK (accept-invite). Premier admin : créateur du doc companies. */
    match /users/{userId}/company_memberships/{companyId} {
      allow read: if isAuthed() && request.auth.uid == userId;
      allow create: if isAuthed()
        && request.auth.uid == userId
        && request.resource.data.role == 'admin'
        && exists(/databases/$(database)/documents/companies/$(companyId))
        && get(/databases/$(database)/documents/companies/$(companyId)).data.createdByUid == request.auth.uid
        && request.resource.data.keys().hasAll(['role', 'joinedAt', 'companyName']);
      allow update, delete: if false;
    }

    /** Jetons Web Push FCM — uniquement le propriétaire Auth peut les gérer. */
    match /users/{userId}/fcm_tokens/{tokenId} {
      allow read, write: if isAuthed() && request.auth.uid == userId;
    }

    match /company_invites/{inviteId} {
      allow read: if isAuthed() && (
        resource.data.invitedByUid == request.auth.uid
        || (
          userBelongsToCompany(resource.data.companyId)
          && userRoleInCompany(resource.data.companyId) == 'admin'
        )
      );
      allow create: if isAuthed()
        && request.resource.data.keys().hasAll(['companyId', 'phone', 'role', 'createdAt', 'invitedByUid'])
        && request.resource.data.invitedByUid == request.auth.uid
        && request.resource.data.role == 'collaborateur'
        && userBelongsToCompany(request.resource.data.companyId)
        && userRoleInCompany(request.resource.data.companyId) == 'admin';
      allow update, delete: if false;
    }

    /** Back-office : membership Firestore (sync-claims pas encore fait ou repli). */
    function canReadInterventionViaMembership() {
      return isAuthed()
        && interventionHasTenantScope(resource.data)
        && userBelongsToCompany(resource.data.companyId);
    }

    /** Portail société : jetons `bmTenants` (cf. /api/company/sync-claims). */
    function canReadInterventionViaTenantClaims() {
      return isAuthed()
        && isCompanyPortalUser()
        && interventionHasTenantScope(resource.data)
        && tenantClaimsIncludeCompany(resource.data.companyId);
    }

    /** Technicien : requêtes `where("assignedTechnicianUid","==", request.auth.uid)`. */
    function canReadInterventionAsAssignee() {
      return isAuthed()
        && resource.data.keys().hasAny(['assignedTechnicianUid'])
        && resource.data.assignedTechnicianUid is string
        && resource.data.assignedTechnicianUid.size() > 0
        && resource.data.assignedTechnicianUid == request.auth.uid;
    }

    /** Demandeur : ses créations (`createdByUid`). */
    function canReadInterventionAsCreator() {
      return isAuthed()
        && resource.data.keys().hasAny(['createdByUid'])
        && resource.data.createdByUid == request.auth.uid;
    }

    /**
     * Seeds partagés staging / dev (`demo-local-company`, `demo-tech-local`).
     * Retirer en prod stricte quand plus aucun doc de démo en base.
     */
    function canReadInterventionDemoStaging() {
      return isAuthed()
        && (
          (
            interventionHasTenantScope(resource.data)
            && resource.data.companyId == 'demo-local-company'
          )
          || (
            resource.data.keys().hasAny(['assignedTechnicianUid'])
            && resource.data.assignedTechnicianUid == 'demo-tech-local'
          )
        );
    }

    function interventionCreateTenantAllowed(data) {
      return !data.keys().hasAny(['companyId'])
        || !(data.companyId is string)
        || data.companyId.size() == 0
        || data.companyId == 'demo-local-company'
        || tenantClaimsIncludeCompany(data.companyId)
        || userBelongsToCompany(data.companyId);
    }

    /** Facturation / commissions : réservés admin tenant ou membership (webhook Stripe = Admin SDK). */
    function interventionSensitiveBillingUnchanged() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny([
        'paymentStatus',
        'stripePaymentLinkUrl',
        'stripePaymentIntentId',
        'paidAt',
        'invoiceAmountCents',
        'commissionAmountCents',
        'commissionRuleId',
        'invoicePdfUrl',
        'invoicedAt',
      ]);
    }

    function canUpdateInterventionAsTenantStaff() {
      return isCompanyPortalUser()
        && interventionHasTenantScope(resource.data)
        && tenantClaimsIncludeCompany(resource.data.companyId)
        && (
          request.auth.token.bmTenants.hasAny([resource.data.companyId + ':admin'])
          || (
            request.auth.token.bmTenants.hasAny([resource.data.companyId + ':collaborateur'])
            && resource.data.keys().hasAny(['createdByUid'])
            && resource.data.createdByUid == request.auth.uid
            && interventionSensitiveBillingUnchanged()
          )
          || tenantCollaborateurCanValidateReport()
        );
    }

    function canUpdateInterventionViaMembershipStaff() {
      return interventionHasTenantScope(resource.data)
        && userBelongsToCompany(resource.data.companyId)
        && (
          userRoleInCompany(resource.data.companyId) == 'admin'
          || (
            userRoleInCompany(resource.data.companyId) == 'collaborateur'
            && resource.data.keys().hasAny(['createdByUid'])
            && resource.data.createdByUid == request.auth.uid
            && interventionSensitiveBillingUnchanged()
          )
        );
    }

    function canUpdateInterventionAsAssignee() {
      return resource.data.keys().hasAny(['assignedTechnicianUid'])
        && resource.data.assignedTechnicianUid is string
        && resource.data.assignedTechnicianUid.size() > 0
        && resource.data.assignedTechnicianUid == request.auth.uid
        && interventionSensitiveBillingUnchanged();
    }

    /** Staging : technicien démo (assignations `demo-tech-local`). */
    function canUpdateInterventionDemoAssignee() {
      return resource.data.keys().hasAny(['assignedTechnicianUid'])
        && resource.data.assignedTechnicianUid == 'demo-tech-local'
        && interventionSensitiveBillingUnchanged();
    }

    function canDeleteInterventionAsAdmin() {
      return interventionHasTenantScope(resource.data)
        && (
          (
            isCompanyPortalUser()
            && request.auth.token.bmTenants.hasAny([resource.data.companyId + ':admin'])
          )
          || (
            userBelongsToCompany(resource.data.companyId)
            && userRoleInCompany(resource.data.companyId) == 'admin'
          )
        );
    }

    /** Alertes doublons — créées après analyse locale des nouvelles demandes (tenant). */
    match /intervention_duplicate_alerts/{alertId} {
      allow read: if isAuthed()
        && resource.data.keys().hasAll([
          'companyId',
          'newInterventionId',
          'similarInterventionId',
          'similarAddress',
          'similarProblemPreview',
          'similarCreatedAt',
          'status',
          'createdByUid',
          'detectedAt',
        ])
        && (
          tenantClaimsIncludeCompany(resource.data.companyId)
          || resource.data.companyId == 'demo-local-company'
        );

      allow create: if isAuthed()
        && request.resource.data.keys().hasAll([
          'companyId',
          'newInterventionId',
          'similarInterventionId',
          'similarAddress',
          'similarProblemPreview',
          'similarCreatedAt',
          'status',
          'createdByUid',
          'detectedAt',
        ])
        && request.resource.data.companyId is string
        && request.resource.data.status == 'open'
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.newInterventionId == alertId
        && (
          tenantClaimsIncludeCompany(request.resource.data.companyId)
          || request.resource.data.companyId == 'demo-local-company'
        );

      allow update: if isAuthed()
        && resource.data.companyId is string
        && tenantClaimsIncludeCompany(resource.data.companyId)
        && request.auth.token.bmTenants.hasAny([resource.data.companyId + ':admin'])
        && resource.data.status == 'open'
        && request.resource.data.status in ['ignored', 'merged']
        && request.resource.data.companyId == resource.data.companyId
        && request.resource.data.newInterventionId == resource.data.newInterventionId
        && request.resource.data.similarInterventionId == resource.data.similarInterventionId
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.detectedAt == resource.data.detectedAt
        && request.resource.data.resolvedAt is string
        && request.resource.data.resolvedByUid == request.auth.uid;

      allow delete: if false;
    }

    match /interventions/{docId} {
      /**
       * Plusieurs `allow read` → OU logique. Garder des règles **séparées** (pas un seul `||` géant)
       * pour que les requêtes filtrées (`companyId`, `assignedTechnicianUid`) passent la validation Firestore.
       * Voir docs/FIRESTORE_PRODUCTION_MIGRATION.md
       */
      allow read: if canReadInterventionViaTenantClaims();
      allow read: if canReadInterventionViaMembership();
      allow read: if canReadInterventionAsAssignee();
      allow read: if canReadInterventionAsCreator();
      allow read: if canReadInterventionDemoStaging();

      allow create: if isAuthed()
        && request.resource.data.keys().hasAny(['createdByUid'])
        && request.resource.data.createdByUid == request.auth.uid
        && interventionCreateTenantAllowed(request.resource.data);

      allow update: if isAuthed() && (
        canUpdateInterventionAsTenantStaff()
        || canUpdateInterventionViaMembershipStaff()
        || canUpdateInterventionAsAssignee()
        || canUpdateInterventionDemoAssignee()
      );

      allow delete: if isAuthed() && canDeleteInterventionAsAdmin();

      match /status_events/{eventId} {
        allow read: if isAuthed();
        allow create: if isAuthed()
          && request.resource.data.interventionId == docId
          && request.resource.data.actorUid == request.auth.uid;
        allow update, delete: if false;
      }

      match /timeline_events/{eventId} {
        allow read: if isAuthed();
        allow create: if isAuthed()
          && request.resource.data.interventionId == docId
          && request.resource.data.createdByUid == request.auth.uid
          && request.resource.data.type == 'comment'
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 8000;
        allow update, delete: if false;
      }
    }

    match /users/{userId}/intervention_alerts/{alertId} {
      allow read, update: if isAuthed() && request.auth.uid == userId;
      allow create: if isAuthed()
        && request.resource.data.actorUid == request.auth.uid;
      allow delete: if false;
    }

    /** Brouillon formulaire demande d’intervention — une entrée par utilisateur authentifié (doc id = uid). */
    match /intervention_request_drafts/{userId} {
      allow read: if isAuthed() && request.auth.uid == userId;
      allow create: if isAuthed() && request.auth.uid == userId;
      allow update: if isAuthed() && request.auth.uid == userId;
      allow delete: if isAuthed() && request.auth.uid == userId;
    }

    /** Profils portail client (SSO / magic link) — doc id = Firebase Auth uid. */
    match /client_portal_profiles/{uid} {
      allow read: if isAuthed() && request.auth.uid == uid;
      allow create: if isAuthed()
        && request.auth.uid == uid
        && request.resource.data.uid == uid;
      allow update: if isAuthed()
        && request.auth.uid == uid
        && request.resource.data.uid == uid;
      allow delete: if false;
    }

    // --- Collections BelgMap existantes ---
    match /allowed_users/{phone} {
      allow read: if isAuthed();
      allow write: if false;
    }

    match /technicians/{docId} {
      allow read, write: if isAuthed();
    }

    match /ai_status/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /ai_audio_decisions/{docId} {
      allow read, write: if isAuthed();
    }

    match /portal_ivana_chat_messages/{msgId} {
      allow read: if isAuthed()
        && resource.data.companyId is string
        && canAccessIvanaPortalChatCompany(resource.data.companyId);

      allow create: if isAuthed()
        && request.resource.data.keys().hasAll(['companyId', 'body', 'role', 'senderUid'])
        && request.resource.data.companyId is string
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 12000
        && request.resource.data.role in ['client', 'staff']
        && request.resource.data.senderUid == request.auth.uid
        && canAccessIvanaPortalChatCompany(request.resource.data.companyId)
        && (
          request.resource.data.body.size() > 0
          || (
            request.resource.data.keys().hasAny(['imageUrls'])
            && request.resource.data.imageUrls is list
            && request.resource.data.imageUrls.size() > 0
          )
        )
        && (
          !request.resource.data.keys().hasAny(['imageUrls'])
          || (
            request.resource.data.imageUrls is list
            && request.resource.data.imageUrls.size() <= 12
          )
        )
        && (
          !request.resource.data.keys().hasAny(['interventionId'])
          || request.resource.data.interventionId is string
        );

      allow update, delete: if false;
    }

    match /commission_rules/{ruleId} {
      allow read: if isAuthed()
        && resource.data.companyId is string
        && (
          userBelongsToCompany(resource.data.companyId)
          || tenantClaimsIncludeCompany(resource.data.companyId)
        );

      allow create: if isAuthed()
        && request.resource.data.companyId is string
        && request.resource.data.createdByUid == request.auth.uid
        && (
          userBelongsToCompany(request.resource.data.companyId)
          || tenantClaimsIncludeCompany(request.resource.data.companyId)
        );

      allow update: if isAuthed()
        && resource.data.companyId is string
        && (
          userBelongsToCompany(resource.data.companyId)
          || tenantClaimsIncludeCompany(resource.data.companyId)
        )
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'isActive', 'updatedAt', 'level', 'targetId', 'valueType', 'value'
        ]);

      allow delete: if false;
    }

    match /commission_rule_audit/{auditId} {
      allow read: if isAuthed()
        && resource.data.companyId is string
        && (
          userBelongsToCompany(resource.data.companyId)
          || tenantClaimsIncludeCompany(resource.data.companyId)
        );
      allow create: if isAuthed()
        && request.resource.data.companyId is string
        && request.resource.data.byUid == request.auth.uid
        && (
          userBelongsToCompany(request.resource.data.companyId)
          || tenantClaimsIncludeCompany(request.resource.data.companyId)
        );
      allow update, delete: if false;
    }

    match /commission_overrides/{interventionId} {
      allow read: if isAuthed()
        && resource.data.companyId is string
        && (
          userBelongsToCompany(resource.data.companyId)
          || tenantClaimsIncludeCompany(resource.data.companyId)
        );
      allow create, update: if isAuthed()
        && request.resource.data.companyId is string
        && (
          userBelongsToCompany(request.resource.data.companyId)
          || tenantClaimsIncludeCompany(request.resource.data.companyId)
        );
      allow delete: if false;
    }

    match /commission_audit/{auditId} {
      allow read: if isAuthed()
        && resource.data.companyId is string
        && (
          userBelongsToCompany(resource.data.companyId)
          || tenantClaimsIncludeCompany(resource.data.companyId)
        );
      allow create: if isAuthed()
        && request.resource.data.companyId is string
        && (
          userBelongsToCompany(request.resource.data.companyId)
          || tenantClaimsIncludeCompany(request.resource.data.companyId)
        );
      allow update, delete: if false;
    }

    match /manual_commissions/{companyId}/entries/{entryId} {
      allow read: if isAuthed()
        && (
          userBelongsToCompany(companyId)
          || tenantClaimsIncludeCompany(companyId)
        );
      allow create: if isAuthed()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.technicianUid is string
        && request.resource.data.technicianUid.size() > 0
        && request.resource.data.amountEuros is number
        && request.resource.data.amountEuros >= 0
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && (
          userBelongsToCompany(companyId)
          || tenantClaimsIncludeCompany(companyId)
        );
      allow update, delete: if false;
    }

    match /material_orders/{orderId} {
      allow read: if isAuthed()
        && (
          !resource.data.keys().hasAny(['companyId'])
          || resource.data.companyId == null
          || (
            resource.data.companyId is string
            && (
              userBelongsToCompany(resource.data.companyId)
              || tenantClaimsIncludeCompany(resource.data.companyId)
            )
          )
          || resource.data.technicianUid == request.auth.uid
        );

      allow create: if isAuthed()
        && request.resource.data.technicianUid == request.auth.uid
        && request.resource.data.interventionId is string
        && request.resource.data.interventionId.size() > 0
        && request.resource.data.partsRequested is list
        && request.resource.data.status == 'pending';

      allow update: if isAuthed()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt'])
        && (
          resource.data.technicianUid == request.auth.uid
          || (
            resource.data.companyId is string
            && (
              userBelongsToCompany(resource.data.companyId)
              || tenantClaimsIncludeCompany(resource.data.companyId)
            )
          )
        );

      allow delete: if false;
    }

    match /intervention_emails/{emailId} {
      allow read: if isAuthed()
        && resource.data.companyId is string
        && (
          userBelongsToCompany(resource.data.companyId)
          || tenantClaimsIncludeCompany(resource.data.companyId)
        );

      allow create: if isAuthed()
        && request.resource.data.companyId is string
        && request.resource.data.companyId.size() > 0
        && (
          userBelongsToCompany(request.resource.data.companyId)
          || tenantClaimsIncludeCompany(request.resource.data.companyId)
        );

      allow update: if isAuthed()
        && resource.data.companyId is string
        && (
          userBelongsToCompany(resource.data.companyId)
          || tenantClaimsIncludeCompany(resource.data.companyId)
        )
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['readAt']);

      allow delete: if false;
    }

    match /clients/{clientId} {
      allow read: if isAuthed()
        && resource.data.companyId is string
        && (
          userBelongsToCompany(resource.data.companyId)
          || tenantClaimsIncludeCompany(resource.data.companyId)
        );
      allow create: if isAuthed()
        && request.resource.data.companyId is string
        && request.resource.data.companyId.size() > 0
        && (
          userBelongsToCompany(request.resource.data.companyId)
          || tenantClaimsIncludeCompany(request.resource.data.companyId)
        );
      allow update: if isAuthed()
        && resource.data.companyId is string
        && (
          userBelongsToCompany(resource.data.companyId)
          || tenantClaimsIncludeCompany(resource.data.companyId)
        );
      allow delete: if isAuthed()
        && resource.data.companyId is string
        && (
          userBelongsToCompany(resource.data.companyId)
          || tenantClaimsIncludeCompany(resource.data.companyId)
        );
    }

    match /sites/{siteId} {
      allow read: if isAuthed()
        && resource.data.companyId is string
        && (
          userBelongsToCompany(resource.data.companyId)
          || tenantClaimsIncludeCompany(resource.data.companyId)
        );
      allow create: if isAuthed()
        && request.resource.data.companyId is string
        && request.resource.data.companyId.size() > 0
        && (
          userBelongsToCompany(request.resource.data.companyId)
          || tenantClaimsIncludeCompany(request.resource.data.companyId)
        );
      allow update: if isAuthed()
        && resource.data.companyId is string
        && (
          userBelongsToCompany(resource.data.companyId)
          || tenantClaimsIncludeCompany(resource.data.companyId)
        );
      allow delete: if isAuthed()
        && resource.data.companyId is string
        && (
          userBelongsToCompany(resource.data.companyId)
          || tenantClaimsIncludeCompany(resource.data.companyId)
        );
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
